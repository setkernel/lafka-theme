<?xml version="1.0"?>
<ruleset name="Lafka Theme">
	<description>WordPress coding standards for Lafka Theme</description>

	<!-- What to scan -->
	<file>.</file>

	<!-- Show progress and sniff codes in all reports -->
	<arg value="ps"/>
	<arg name="colors"/>
	<arg name="extensions" value="php"/>

	<!-- Warnings are advisory; only errors fail CI. -->
	<arg name="warning-severity" value="0"/>

	<!-- Strip the filepaths down to the relevant bit -->
	<arg name="basepath" value="."/>

	<!-- Rules -->
	<rule ref="WordPress-Extra">
		<!-- Allow short array syntax -->
		<exclude name="Universal.Arrays.DisallowShortArraySyntax"/>

		<!-- Pure stylistic sniffs disabled: codebase pre-dates them and the cleanup
		     would touch hundreds of files for zero functional benefit. Re-enable
		     after a dedicated formatting pass. -->
		<exclude name="WordPress.PHP.YodaConditions.NotYoda"/>
		<exclude name="WordPress.NamingConventions.ValidVariableName.VariableNotSnakeCase"/>
		<exclude name="WordPress.NamingConventions.ValidVariableName.UsedPropertyNotSnakeCase"/>
		<exclude name="WordPress.NamingConventions.ValidFunctionName.MethodNameInvalid"/>
		<exclude name="Squiz.PHP.DisallowMultipleAssignments.Found"/>
		<exclude name="Squiz.PHP.DisallowMultipleAssignments.FoundInControlStructure"/>
		<exclude name="Squiz.PHP.CommentedOutCode.Found"/>
		<exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
		<exclude name="WordPress.Files.FileName.InvalidClassFileName"/>

		<!-- Loose comparisons (== / !=) are pervasive in legacy WP code and the
		     codebase relies on type coercion in many places. Re-enable
		     incrementally during a dedicated audit pass. -->
		<exclude name="Universal.Operators.StrictComparisons.LooseEqual"/>
		<exclude name="Universal.Operators.StrictComparisons.LooseNotEqual"/>
		<exclude name="WordPress.PHP.StrictComparisons.LooseComparison"/>

		<!-- Security sniffs need per-call manual audit, not script-fix
		     (auto-escaping with the wrong escaper context = double-encoded HTML
		     or breaks output). Tracked as P5-Sec; re-enable after that pass. -->
		<exclude name="WordPress.Security.EscapeOutput.OutputNotEscaped"/>
		<exclude name="WordPress.Security.EscapeOutput.UnsafePrintingFunction"/>
		<exclude name="WordPress.Security.NonceVerification.Recommended"/>
		<exclude name="WordPress.Security.NonceVerification.Missing"/>
		<exclude name="WordPress.Security.ValidatedSanitizedInput.InputNotSanitized"/>
		<exclude name="WordPress.Security.ValidatedSanitizedInput.InputNotValidated"/>
		<exclude name="WordPress.Security.ValidatedSanitizedInput.MissingUnslash"/>
		<exclude name="WordPress.PHP.StrictInArray.MissingTrueStrict"/>
		<exclude name="WordPress.DB.PreparedSQL.NotPrepared"/>
		<exclude name="WordPress.DB.PreparedSQL.InterpolatedNotPrepared"/>

		<!-- Polish-tier sniffs that need contextual judgment per call site
		     (date() vs gmdate() depends on whether you want UTC vs local time;
		     translators-comment placement is best done during a translation pass;
		     extract() removal is per-shortcode work). Tracked as P5-Polish. -->
		<exclude name="WordPress.DateTime.RestrictedFunctions.date_date"/>
		<exclude name="WordPress.DateTime.RestrictedFunctions.date_gmmktime"/>
		<exclude name="WordPress.WP.GlobalVariablesOverride.Prohibited"/>
		<exclude name="WordPress.WP.EnqueuedResourceParameters.NoExplicitVersion"/>
		<exclude name="WordPress.WP.EnqueuedResourceParameters.MissingVersion"/>
		<exclude name="WordPress.WP.AlternativeFunctions.json_encode_json_encode"/>
		<exclude name="WordPress.WP.AlternativeFunctions.parse_url_parse_url"/>
		<exclude name="WordPress.WP.AlternativeFunctions.curl_curl_init"/>
		<exclude name="WordPress.WP.AlternativeFunctions.curl_curl_exec"/>
		<exclude name="WordPress.WP.AlternativeFunctions.curl_curl_close"/>
		<exclude name="WordPress.WP.AlternativeFunctions.curl_curl_setopt"/>
		<exclude name="WordPress.PHP.DontExtract.extract_extract"/>
		<exclude name="WordPress.PHP.DevelopmentFunctions.error_log_error_log"/>
		<exclude name="WordPress.WP.I18n.MissingTranslatorsComment"/>
		<exclude name="WordPress.WP.I18n.MissingArgDomain"/>
		<exclude name="WordPress.WP.I18n.NonSingularStringLiteralText"/>
		<exclude name="WordPress.WP.I18n.NonSingularStringLiteralSingle"/>
		<exclude name="WordPress.WP.I18n.NonSingularStringLiteralPlural"/>
		<exclude name="Generic.CodeAnalysis.RequireExplicitBooleanOperatorPrecedence.MissingParentheses"/>
		<exclude name="Generic.CodeAnalysis.AssignmentInCondition.Found"/>
		<exclude name="Generic.CodeAnalysis.UnusedFunctionParameter.FoundAfterLastUsed"/>
		<exclude name="Universal.Operators.DisallowShortTernary.Found"/>
		<exclude name="Universal.Files.SeparateFunctionsFromOO.Mixed"/>
		<exclude name="Generic.Strings.UnnecessaryStringConcat.Found"/>
		<exclude name="Squiz.WhiteSpace.SuperfluousWhitespace.EndLine"/>
		<exclude name="WordPress.WhiteSpace.OperatorSpacing.NoSpaceBefore"/>
		<exclude name="WordPress.WhiteSpace.OperatorSpacing.NoSpaceAfter"/>
		<exclude name="Generic.WhiteSpace.DisallowSpaceIndent.SpacesUsed"/>
	</rule>

	<!-- Check for cross-version PHP compatibility (PHP 7.4 EOL'd 2022; 8.0 EOL'd 2023; 8.1 EOL'd 2024) -->
	<config name="testVersion" value="8.1-"/>
	<rule ref="PHPCompatibilityWP"/>

	<!-- WordPress text domain -->
	<config name="text_domain" value="lafka"/>

	<!-- Minimum supported WordPress version (WP 6.6 = mid-2024 baseline) -->
	<config name="minimum_wp_version" value="6.6"/>

	<!-- Exclude third-party / vendor directories -->
	<exclude-pattern>/vendor/*</exclude-pattern>
	<exclude-pattern>/node_modules/*</exclude-pattern>
	<exclude-pattern>/incl/tgm-plugin-activation/*</exclude-pattern>
	<exclude-pattern>/incl/lafka-options-framework/*</exclude-pattern>
	<!-- PHPUnit tests use their own PascalCase naming convention, not WP kebab-case. -->
	<exclude-pattern>/tests/*</exclude-pattern>
</ruleset>
