# Commercial plugins (must be purchased separately)
plugins/*.zip

# OS files
.DS_Store
Thumbs.db

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo
*~

# Dependencies
node_modules/
vendor/

# WordPress
wp-config.php
wp-content/uploads/

# Test artefacts
.phpunit.result.cache
.tmp-screenshots/
.wp-env-uploads/

# Minified build artefacts (NX1-10b): generated by `npm run build`
# (scripts/build-assets.mjs) and regenerated in release.yml before packaging.
# Never committed — the runtime switch (incl/system/asset-min.php) serves them
# only when present on disk.
/styles/*.min.css
/js/*.min.js
# Exceptions: a few first-party scripts ship a committed, hand-tuned `.min`
# sibling consumed by an existing SCRIPT_DEBUG `$suffix` enqueue, and two
# vendored libraries are distributed only in minified form. Keep these tracked.
!/js/lafka-front.min.js
!/js/lafka-dialog.min.js
!/js/lafka-libs-config.min.js
!/js/lafka-price-slider.min.js
!/js/typed.min.js
!/js/jquery.nice-select.min.js

# Misc
*.log
*.bak
*.orig

# Playwright e2e artifacts
/test-results/
/playwright-report/
/blob-report/
/.playwright/

# NX1-02 visual parity harness (playwright.visual.config.js): goldens are LOCAL,
# machine-specific, and regenerated only intentionally — never committed, never
# run in CI. See tests/visual/nx1-02.spec.js.
/tests/visual/__screenshots__/
/tests/visual/.output/
/tests/visual/.report/
# NX2-07 dark-preset visual gate (playwright.visual.dark.config.js) — same
# LOCAL/untracked contract. See tests/visual/nx2-dark.spec.js.
/tests/visual/.output-dark/
/tests/visual/.report-dark/
