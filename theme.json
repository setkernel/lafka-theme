{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"defaultDuotone": false,
			"palette": [
				{
					"slug": "accent",
					"name": "Accent",
					"color": "#DD430E"
				},
				{
					"slug": "text-primary",
					"name": "Text",
					"color": "#333333"
				},
				{
					"slug": "text-secondary",
					"name": "Text Secondary",
					"color": "#666666"
				},
				{
					"slug": "text-muted",
					"name": "Text Muted",
					"color": "#999999"
				},
				{
					"slug": "background",
					"name": "Background",
					"color": "#ffffff"
				},
				{
					"slug": "background-subtle",
					"name": "Background Subtle",
					"color": "#f8f8f8"
				},
				{
					"slug": "background-input",
					"name": "Background Input",
					"color": "#f6f6f6"
				},
				{
					"slug": "border-light",
					"name": "Border Light",
					"color": "#f1f1f1"
				},
				{
					"slug": "border-default",
					"name": "Border Default",
					"color": "#e8e8e8"
				},
				{
					"slug": "border-medium",
					"name": "Border Medium",
					"color": "#e1e1e1"
				},
				{
					"slug": "border-dark",
					"name": "Border Dark",
					"color": "#cccccc"
				},
				{
					"slug": "status-error",
					"name": "Error",
					"color": "#c23131"
				},
				{
					"slug": "status-warning",
					"name": "Warning",
					"color": "#9d8967"
				},
				{
					"slug": "status-success",
					"name": "Success",
					"color": "#388e3c"
				},
				{
					"slug": "status-info",
					"name": "Info",
					"color": "#008cc9"
				}
			]
		},
		"typography": {
			"customFontSize": true,
			"dropCap": false,
			"fluid": true,
			"fontSizes": [
				{
					"slug": "small",
					"name": "Small",
					"size": "13px"
				},
				{
					"slug": "medium",
					"name": "Medium",
					"size": "16px"
				},
				{
					"slug": "large",
					"name": "Large",
					"size": "20px"
				},
				{
					"slug": "x-large",
					"name": "Extra Large",
					"size": "28px"
				},
				{
					"slug": "xx-large",
					"name": "XX Large",
					"size": "40px"
				}
			]
		},
		"spacing": {
			"customSpacingSize": true,
			"units": ["px", "em", "rem", "vh", "vw", "%"],
			"spacingSizes": [
				{
					"slug": "xs",
					"name": "XS",
					"size": "4px"
				},
				{
					"slug": "sm",
					"name": "Small",
					"size": "8px"
				},
				{
					"slug": "md",
					"name": "Medium",
					"size": "12px"
				},
				{
					"slug": "lg",
					"name": "Large",
					"size": "16px"
				},
				{
					"slug": "xl",
					"name": "XL",
					"size": "20px"
				},
				{
					"slug": "2xl",
					"name": "2XL",
					"size": "24px"
				},
				{
					"slug": "3xl",
					"name": "3XL",
					"size": "30px"
				},
				{
					"slug": "4xl",
					"name": "4XL",
					"size": "40px"
				},
				{
					"slug": "5xl",
					"name": "5XL",
					"size": "50px"
				}
			]
		},
		"layout": {
			"contentSize": "1200px",
			"wideSize": "1400px"
		}
	},
	"styles": {
		"color": {
			"text": "var(--wp--preset--color--text-primary)",
			"background": "var(--wp--preset--color--background)"
		},
		"typography": {
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.6"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--accent)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--accent)"
					}
				}
			},
			"h1": {
				"color": {
					"text": "var(--wp--preset--color--text-primary)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"lineHeight": "1.2"
				}
			},
			"h2": {
				"color": {
					"text": "var(--wp--preset--color--text-primary)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"lineHeight": "1.25"
				}
			},
			"h3": {
				"color": {
					"text": "var(--wp--preset--color--text-primary)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"lineHeight": "1.3"
				}
			},
			"button": {
				"color": {
					"text": "#ffffff",
					"background": "var(--wp--preset--color--accent)"
				},
				":hover": {
					"color": {
						"background": "#c43d0d"
					}
				}
			}
		}
	}
}
