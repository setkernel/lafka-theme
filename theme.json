{
	"$schema": "https://schemas.wp.org/wp/6.6/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"defaultDuotone": false,
			"palette": [
				{
					"slug": "accent",
					"name": "Accent",
					"color": "#dc2626"
				},
				{
					"slug": "text-primary",
					"name": "Text",
					"color": "#18181b"
				},
				{
					"slug": "text-secondary",
					"name": "Text Secondary",
					"color": "#3f3f46"
				},
				{
					"slug": "text-muted",
					"name": "Text Muted",
					"color": "#71717a"
				},
				{
					"slug": "background",
					"name": "Background",
					"color": "#fff"
				},
				{
					"slug": "background-subtle",
					"name": "Background Subtle",
					"color": "#fafafa"
				},
				{
					"slug": "background-input",
					"name": "Background Input",
					"color": "#fafafa"
				},
				{
					"slug": "border-light",
					"name": "Border Light",
					"color": "#e4e4e7"
				},
				{
					"slug": "border-default",
					"name": "Border Default",
					"color": "#d4d4d8"
				},
				{
					"slug": "border-medium",
					"name": "Border Medium",
					"color": "#d4d4d8"
				},
				{
					"slug": "border-dark",
					"name": "Border Dark",
					"color": "#a1a1aa"
				},
				{
					"slug": "status-error",
					"name": "Error",
					"color": "#b91c1c"
				},
				{
					"slug": "status-warning",
					"name": "Warning",
					"color": "#b45309"
				},
				{
					"slug": "status-success",
					"name": "Success",
					"color": "#047857"
				},
				{
					"slug": "status-info",
					"name": "Info",
					"color": "#1d4ed8"
				}
			]
		},
		"typography": {
			"customFontSize": true,
			"dropCap": false,
			"fluid": true,
			"fontSizes": [
				{
					"slug": "small",
					"name": "Small",
					"size": "0.8125rem"
				},
				{
					"slug": "medium",
					"name": "Medium",
					"size": "1rem"
				},
				{
					"slug": "large",
					"name": "Large",
					"size": "1.25rem"
				},
				{
					"slug": "x-large",
					"name": "Extra Large",
					"size": "28px"
				},
				{
					"slug": "xx-large",
					"name": "XX Large",
					"size": "2.5rem"
				}
			],
			"fontFamilies": [
				{
					"slug": "body",
					"name": "Body",
					"fontFamily": "\"Rubik\", system-ui, -apple-system, \"Segoe UI\", roboto, \"Helvetica Neue\", arial, sans-serif"
				},
				{
					"slug": "display",
					"name": "Display",
					"fontFamily": "\"Fraunces\", \"Iowan Old Style\", \"Palatino Linotype\", \"Book Antiqua\", palatino, georgia, serif"
				},
				{
					"slug": "mono",
					"name": "Mono",
					"fontFamily": "ui-monospace, sfmono-regular, \"SF Mono\", menlo, consolas, monospace"
				}
			]
		},
		"spacing": {
			"customSpacingSize": true,
			"units": ["px", "em", "rem", "vh", "vw", "%"],
			"spacingSizes": [
				{
					"slug": "xs",
					"name": "XS",
					"size": "4px"
				},
				{
					"slug": "sm",
					"name": "Small",
					"size": "8px"
				},
				{
					"slug": "md",
					"name": "Medium",
					"size": "12px"
				},
				{
					"slug": "lg",
					"name": "Large",
					"size": "16px"
				},
				{
					"slug": "xl",
					"name": "XL",
					"size": "20px"
				},
				{
					"slug": "2xl",
					"name": "2XL",
					"size": "24px"
				},
				{
					"slug": "3xl",
					"name": "3XL",
					"size": "30px"
				},
				{
					"slug": "4xl",
					"name": "4XL",
					"size": "40px"
				},
				{
					"slug": "5xl",
					"name": "5XL",
					"size": "50px"
				}
			]
		},
		"layout": {
			"contentSize": "1200px",
			"wideSize": "1400px"
		}
	},
	"styles": {
		"color": {
			"text": "var(--wp--preset--color--text-primary)",
			"background": "var(--wp--preset--color--background)"
		},
		"typography": {
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.6"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--accent)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--accent)"
					}
				}
			},
			"h1": {
				"color": {
					"text": "var(--wp--preset--color--text-primary)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"lineHeight": "1.2"
				}
			},
			"h2": {
				"color": {
					"text": "var(--wp--preset--color--text-primary)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"lineHeight": "1.25"
				}
			},
			"h3": {
				"color": {
					"text": "var(--wp--preset--color--text-primary)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"lineHeight": "1.3"
				}
			},
			"button": {
				"color": {
					"text": "#ffffff",
					"background": "var(--wp--preset--color--accent)"
				},
				":hover": {
					"color": {
						"background": "#c43d0d"
					}
				}
			}
		}
	}
}
